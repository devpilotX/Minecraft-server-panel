cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnpm-store/

# Next.js
.next/
out/

# Environment
.env
.env.local
.env.production
.env*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Turbopack
.turbo/

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts
EOF